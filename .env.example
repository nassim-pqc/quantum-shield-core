# =============================================================================
# Quantum Shield Core — Environment template
# Copy to .env and replace ALL placeholder values. Never commit .env.
# =============================================================================

# --- PostgreSQL (docker compose) ---
POSTGRES_USER=qshield
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=quantum_shield

# Overridden by docker-compose for the API service:
# DATABASE_URL=postgresql+asyncpg://qshield:PASSWORD@postgres:5432/quantum_shield

# --- Audit HMAC (min 32 characters; rotation: AUDIT_KEY_v2, v3, ...) ---
AUDIT_KEY_v1=REPLACE_WITH_AUDIT_HMAC_KEY_VERSION_1_MIN_32_CHARS
ACTIVE_AUDIT_KEY_VERSION=v1

# --- API keys (seeded on first startup; min 32 characters each) ---
API_KEY_OPERATOR=REPLACE_WITH_OPERATOR_API_KEY_MIN_32_CHARS
API_KEY_AUDITOR=REPLACE_WITH_AUDITOR_API_KEY_MIN_32_CHARS

# --- KMS Provider: local | aws | vault | azure ---
KMS_PROVIDER=local

# --- HashiCorp Vault (when KMS_PROVIDER=vault) ---
# VAULT_ADDR=https://vault:8200
# VAULT_TOKEN=hvs.your-token-here
# VAULT_KV_PATH=quantum-shield/audit-keys
# VAULT_KV_MOUNT=secret
# VAULT_TIMEOUT=10
# VAULT_MAX_RETRIES=3
# VAULT_RETRY_DELAY=1.0

# --- AWS KMS (when KMS_PROVIDER=aws) ---
# AWS_KMS_KEY_ID=alias/quantum-shield-audit
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# KMS_DEK_ALGORITHM=AES_256
# KMS_MAX_RETRIES=3
# KMS_RETRY_DELAY=1.0

# --- API ---
ENABLE_DOCS=true
ALLOWED_ORIGINS=
LOG_LEVEL=INFO
ENABLE_HSTS=true

# --- Uvicorn ---
UVICORN_WORKERS=4
UVICORN_TIMEOUT_KEEP_ALIVE=30

# --- OpenTelemetry (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=quantum-shield-core
# OTEL_EXPORTER_INSECURE=true
